# --- Server ---
PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Session signing (HMAC-SHA256). Generate with: openssl rand -hex 32 ---
SESSION_SECRET=change-me-to-a-64-char-hex-string

# --- Spotify OAuth ---
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_REDIRECT_URI=http://localhost:8787/auth/callback

# Space-separated scopes. Adjust as needed.
SPOTIFY_SCOPES=user-read-private user-read-email user-top-read user-read-currently-playing playlist-modify-public playlist-modify-private

# After OAuth success, redirect the browser back here.
FRONTEND_POST_LOGIN_URL=http://localhost:5173/app

# --- Fixtures ---
# When true, all /api/* endpoints return deterministic canned data
# and OAuth is bypassed. Use this to run the app without a Spotify dev account.
SPOTIFY_FIXTURE_MODE=true

# --- Cache ---
CACHE_TTL_SECONDS=90
